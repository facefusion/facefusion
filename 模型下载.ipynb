   "source": [
    "# 模型路径\n",
    "``` shell\n",
    "if [ -e ~/facefusion/.assets/models ]; then\n",
    "    mv ~/facefusion/.assets/models ~/autodl-tmp/facefusion/\n",
    "fi\n",
    "\n",
    "ln -s /root/autodl-tmp/facefusion/models ~/facefusion/.assets/models\n",
    "```"
   ]
  },
